{
  "$schema": "./zskills-config.schema.json",
  "project_name": "scorebook",
  "timezone": "America/New_York",
  "execution": {
    "landing": "cherry-pick",
    "main_protected": false,
    "branch_prefix": "feat/"
  },
  "testing": {
    "unit_cmd": "",
    "full_cmd": "",
    "output_file": ".test-results.txt",
    "file_patterns": []
  },
  "dev_server": {
    "cmd": "npm start",
    "port_script": "",
    "main_repo_path": "/workspaces/scorebook"
  },
  "ui": {
    "file_patterns": "src/.*\\.(html|js|css)",
    "auth_bypass": ""
  },
  "ci": {
    "auto_fix": true,
    "max_fix_attempts": 2
  }
}
